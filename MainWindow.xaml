<Window x:Class="SmashTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SmashTracker"
        mc:Ignorable="d"
        Title="SmashTracker" Height="500" Width="800" Background="#1E1E24"
        Icon="SmashTracker.ico">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Xolonium"/>
            <Setter Property="Foreground" Value="#F8F9FA"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="FontFamily" Value="Xolonium"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="FontFamily" Value="Xolonium"/>
            <Setter Property="Background" Value="#2A2A35"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444455"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="5"/>
        </Style>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="0,0,30,0">
            <TextBlock Text="SELECT CHARACTER:" Margin="0,0,0,5"  FontSize="18"  FontWeight="Bold" TextDecorations="Underline"/>

            <ComboBox Name="CharacterDropdown" Width="250" HorizontalAlignment="Left" Margin="0,0,0,20" Height="30" Background="#FFA4B3ED" Foreground="Black" SelectionChanged="CharacterDropdown_SelectionChanged">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{Binding ImagePath}" Width="25" Height="25" Margin="0,0,10,0"/>
                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontFamily="Cascadia Code" FontSize="16" FontWeight="Bold"/>
                        </StackPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <Button Name="WinButton" Content="ADD WIN" Width="110" Height="30" Margin="0,0,10,0" Click="WinButton_Click" Background="#2DEB85"/>
                <Button Name="LoseButton" Content="ADD LOSS" Width="110" Height="30" Click="LoseButton_Click" Background="#FF3366"/>
            </StackPanel>

            <TextBlock Name="OutputText" FontSize="14" Foreground="#2DEB85"/>
        </StackPanel>

        <StackPanel Grid.Column="1">
            <TextBlock Text="MATCHUP STATS" FontWeight="Bold" FontSize="24"  TextDecorations="Underline" Margin="0,0,0,10"/>

            <TextBlock Name="StatsDisplay" Text="Wins: 0 | Losses: 0 | Winrate: 0%" FontSize="16" Margin="0,0,0,20"/>

            <TextBlock Text="MATCHUP NOTES:" FontWeight="Bold" FontSize="16" FontFamily="Xolonium" Margin="0,0,0,5"/>

            <TextBox Name="NotesTextBox" Height="250" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10"/>

            <Button Name="SaveNotesButton" Content="SAVE NOTES" Width="140" Height="30" HorizontalAlignment="Right" Click="SaveNotesButton_Click" Background="#00C3E3"/>
        </StackPanel>
    </Grid>
</Window>
